# IMS Malawi Union - Environment Variables Template
# Copy this to .env and fill in your values

# Database Configuration
DB_NAME=ims_malawi_db
DB_USER=ims_admin
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Django Security
SECRET_KEY=your-super-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Payment Gateways
AIRTEL_API_KEY=your-key-here
AIRTEL_API_SECRET=your-secret-here
TNM_API_KEY=your-key-here

# YouTube API
YOUTUBE_API_KEY=your-youtube-api-key